{
  "name": "journey-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "mongodb": "cd /Users/lishuxue/Documents/study/journey/journey-docker && docker compose -f docker-compose.dev.yml up -d journey-mongodb",
    "mongodb-down": "cd /Users/lishuxue/Documents/study/journey/journey-docker && docker compose -f docker-compose.dev.yml down journey-mongodb",
    "dev": "yarn build && cross-env NODE_ENV=development nodemon --delay 3 --watch dist dist/server.js",
    "build": "tsc",
    "start": "yarn build && pm2 start pm2.config.json --env prd",
    "stop": " pm2 stop journey-server",
    "re-start": "yarn stop && yarn start",
    "lint": "tsc --noEmit && eslint --ext .js --ext .ts .",
    "lint-fix": "eslint --fix --ext .js --ext .ts .",
    "format": "prettier --write src/",
    "prepare": "husky install"
  },
  "dependencies": {
    "@sentry/node": "^7.51.0",
    "axios": "^1.4.0",
    "cheerio": "^1.0.0-rc.12",
    "dayjs": "^1.11.9",
    "jsonwebtoken": "^9.0.1",
    "koa": "^2.14.2",
    "koa-bodyparser": "^4.4.1",
    "koa-router": "^12.0.0",
    "koa2-cors": "^2.0.6",
    "koa2-ratelimit": "^1.1.3",
    "log4js": "^6.9.1",
    "mongodb": "^5.7.0",
    "node-schedule": "^2.1.1",
    "nodemailer": "^6.7.7",
    "qiniu": "^7.8.0"
  },
  "devDependencies": {
    "@tsconfig/node18": "^2.0.1",
    "@types/cheerio": "^0.22.31",
    "@types/jsonwebtoken": "^9.0.1",
    "@types/koa": "^2.13.6",
    "@types/koa-bodyparser": "^4.3.10",
    "@types/koa-router": "^7.4.4",
    "@types/koa2-cors": "^2.0.2",
    "@types/koa2-ratelimit": "^0.9.6",
    "@types/node-schedule": "^1.3.2",
    "@types/nodemailer": "^6.4.4",
    "@typescript-eslint/eslint-plugin": "^6.2.0",
    "@typescript-eslint/parser": "^6.2.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.45.0",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^8.0.3",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.0",
    "typescript": "^5.1.6"
  }
}
