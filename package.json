{
  "name": "journey-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "rm -rf dist && tsc",
    "dev": "mongod & yarn build && cross-env NODE_ENV=development node dist/server.js",
    "start": "yarn build && pm2 start pm2.config.json --env prd",
    "stop": " pm2 stop journey-server",
    "re-start": "yarn stop && yarn start"
  },
  "dependencies": {
    "@sentry/node": "^5.5.0",
    "jsonwebtoken": "^8.3.0",
    "koa": "^2.5.2",
    "koa-bodyparser": "^4.2.1",
    "koa-router": "^7.4.0",
    "koa2-cors": "^2.0.6",
    "mongoose": "^5.2.13",
    "qiniu": "^7.2.2"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^8.3.3",
    "@types/koa": "^2.0.49",
    "@types/koa-bodyparser": "^4.3.0",
    "@types/koa-router": "^7.0.42",
    "@types/koa2-cors": "^2.0.1",
    "@types/mongoose": "^5.5.12",
    "cross-env": "^5.2.0",
    "typescript": "^3.5.3"
  }
}
