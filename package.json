{
  "name": "journey-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "mongod & cross-env NODE_ENV=development node server.js",
    "start": "pm2 start mongod && pm2 start node server.js",
    "stop": "pm2 stop mongod && pm2 stop node server",
    "re-start": "yarn stop && yarn start"
  },
  "dependencies": {
    "jsonwebtoken": "^8.3.0",
    "koa": "^2.5.2",
    "koa-bodyparser": "^4.2.1",
    "koa-router": "^7.4.0",
    "koa2-cors": "^2.0.6",
    "mongoose": "^5.2.13",
    "qiniu": "^7.2.2"
  },
  "devDependencies": {
    "cross-env": "^5.2.0"
  }
}
