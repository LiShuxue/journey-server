{
  "name": "journey-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "mongod-mac": "mongod -f /Users/lishuxue/Documents/software/mongodb-osx-x86_64-3.6.23/config/mongod.conf",
    "mongod-win": "mongod -f E:\\Front\\mongodb\\bin\\mongod.cfg --auth",
    "dev": "cross-env NODE_ENV=development nodemon --delay 3 --watch dist dist/server.js",
    "build": "tsc",
    "start": "yarn build && pm2 start pm2.config.json --env prd",
    "stop": " pm2 stop journey-server",
    "re-start": "yarn stop && yarn start",
    "lint": "eslint --ext .js --ext .ts .",
    "lint-fix": "eslint --fix --ext .js --ext .ts ."
  },
  "husky": {
    "hooks": {
      "pre-push": "yarn lint"
    }
  },
  "dependencies": {
    "@sentry/node": "^5.5.0",
    "axios": "^0.21.1",
    "cheerio": "^1.0.0-rc.9",
    "jsonwebtoken": "^8.3.0",
    "koa": "^2.5.2",
    "koa-bodyparser": "^4.2.1",
    "koa-router": "^7.4.0",
    "koa2-cors": "^2.0.6",
    "log4js": "^6.4.0",
    "mongoose": "^5.2.13",
    "node-schedule": "^2.0.0",
    "nodemailer": "^6.6.0",
    "qiniu": "^7.2.2"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.28",
    "@types/jsonwebtoken": "^8.3.3",
    "@types/koa": "^2.0.49",
    "@types/koa-bodyparser": "^4.3.0",
    "@types/koa-router": "^7.0.42",
    "@types/koa2-cors": "^2.0.1",
    "@types/mongoose": "^5.5.12",
    "@types/node-schedule": "^1.3.1",
    "@types/nodemailer": "^6.4.1",
    "@typescript-eslint/eslint-plugin": "^4.5.0",
    "@typescript-eslint/parser": "^4.5.0",
    "cross-env": "^5.2.0",
    "eslint": "^6.7.2",
    "eslint-plugin-prettier": "^3.1.3",
    "husky": "^4.3.6",
    "nodemon": "^2.0.2",
    "prettier": "^1.19.1",
    "typescript": "^3.5.3"
  }
}
